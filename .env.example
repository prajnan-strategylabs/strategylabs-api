# ── Supabase ──────────────────────────────────────────────────────────────────
# Project URL from Settings → API
SUPABASE_URL=https://your-project.supabase.co

# Service-role key — NEVER expose this to the browser or commit it.
# Settings → API → service_role secret (sb_secret_...)
SUPABASE_SECRET_KEY=sb_secret_...

# JWT secret — Settings → API → JWT secret
# Used to verify Supabase-issued access tokens without a round-trip to Supabase.
SUPABASE_JWT_SECRET=your-jwt-secret-here

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (no trailing slash)
ALLOWED_ORIGINS=http://localhost:5173,https://strategylabs.trade
