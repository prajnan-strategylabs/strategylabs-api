# ── Supabase ──────────────────────────────────────────────────────────────────
# Project URL from Settings → API
SUPABASE_URL=https://your-project.supabase.co

# Service-role key — NEVER expose this to the browser or commit it.
# Settings → API → service_role secret (sb_secret_...)
SUPABASE_SECRET_KEY=sb_secret_...

# JWT secret — Settings → API → JWT secret
# Used to verify Supabase-issued access tokens without a round-trip to Supabase.
SUPABASE_JWT_SECRET=your-jwt-secret-here

# ── Feature flags ─────────────────────────────────────────────────────────────
# Once the public app is open (no longer waitlist-gated), set this to "true".
# Hero on landing page swaps "Join waitlist" CTA for "Launch app".
IS_LAUNCHED=false

# When the current beta cohort is full and we want to stop accepting new
# waitlist signups, set this to "true". Hero shows a "Waitlist is full"
# message, the dashboard gate shows the same to logged-in users not yet on
# the list, AND the POST /api/v1/waitlist endpoint returns 403 (defense in
# depth — UI can't be bypassed by hitting the API directly).
WAITLIST_FULL=false

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (no trailing slash)
ALLOWED_ORIGINS=http://localhost:5173,https://strategylabs.trade
